# Sophos XGS Firewall
SOPHOS_HOST=192.168.1.1
SOPHOS_PORT=4444
SOPHOS_USERNAME=admin
SOPHOS_PASSWORD=your_password
SOPHOS_MAC_GROUP=NetGuard-DirectInternet

# Google OAuth (create at console.cloud.google.com)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Comma-separated list of allowed Google emails
ALLOWED_EMAILS=admin@yourdomain.com,user@yourdomain.com

# JWT secret - generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-random-secret

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173
